#include <stdio.h>
int main() {
    char str[]="hello", sub[]="ell";
    int i,j,flag=0;
    for(i=0;str[i]!='\0';i++){
        for(j=0;sub[j]!='\0';j++){
            if(str[i+j]!=sub[j])
                break;
        }
        if(sub[j]=='\0'){
            flag=1; break;
        }
    }
    if(flag) printf("Found");
    else printf("Not Found");
}
