#include <stdio.h>

int main()
{
    int n, m, i, sum = 0;

    printf("Enter the number (multiple): ");
    scanf("%d", &m);

    printf("Enter the limit n: ");
    scanf("%d", &n);

    for(i = 1; i <= n; i++)
    {
        if(i % m == 0)
        {
            sum = sum + i;
        }
    }

    printf("Sum of multiples = %d", sum);

    return 0;
}
