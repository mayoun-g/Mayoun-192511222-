#include <stdio.h>

int main() {
    int n, i, j, prime, temp, rev, rem, count = 0;

    printf("Enter a number: ");
    scanf("%d", &n);

    printf("Prime numbers:\n");

    for(i = 2; i <= n; i++) {
        prime = 1;

        for(j = 2; j < i; j++) {
            if(i % j == 0) {
                prime = 0;
                break;
            }
        }

        if(prime == 1) {
            printf("%d ", i);

            temp = i;
            rev = 0;

            while(temp > 0) {
                rem = temp % 10;
                rev = rev * 10 + rem;
                temp = temp / 10;
            }

            if(rev == i) {
                count++;
            }
        }
    }

    printf("\nPalindrome prime count = %d", count);

    return 0;
}
