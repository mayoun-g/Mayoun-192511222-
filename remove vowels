#include<stdio.h>
void main()
{
    char str[100];
    int i,j=0;

    printf("Enter string: ");
    scanf("%s",str);

    for(i=0;str[i]!='\0';i++){
        if(!(str[i]=='a'||str[i]=='e'||str[i]=='i'||str[i]=='o'||str[i]=='u'))
            str[j++]=str[i];
    }

    str[j]='\0';

    printf("Result: %s",str);
}
