#include <stdio.h>

int main()
{
    int n, i, num;
    int pos_sum = 0, neg_sum = 0;

    printf("Enter how many numbers: ");
    scanf("%d", &n);

    for(i = 1; i <= n; i++)
    {
        printf("Enter number: ");
        scanf("%d", &num);

        if(num >= 0)
            pos_sum = pos_sum + num;
        else
            neg_sum = neg_sum + num;
    }

    printf("Sum of positive numbers = %d\n", pos_sum);
    printf("Sum of negative numbers = %d", neg_sum);

    return 0;
}
